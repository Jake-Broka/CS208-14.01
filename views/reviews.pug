extends layout 

block content 
    div.review-list
        h1 Reviews: 
        ul
            each review in reviews 
                li.review=review.review + ' - ' + review.timestamp

    
    div.pagination-buttons
        if currentPage > 1
            a(href=`/reviews?page=${currentPage - 1}`).prev-button Previous 
        else 
            p.prev-button Previous

        if currentPage < totalPages
            a(href=`/reviews?page=${currentPage + 1}`).next-button Next
        else 
            p.next-button Next

    br
    hr.saffron

    script.  
        var wasSubmitted=false;

        function checkBeforeSubmit(){
            if(!wasSubmitted){
                wasSubmitted = true;
                return wasSubmitted
            }
            return false;
        }

    div.review-form
        h2 Leave a Review!
        form(method='POST' action='/reviews/send' onsubmit="return checkBeforeSubmit()")
            label(for='review' style='display:block; margin-bottom:10px') Write your review: 
            input(type='text', name ='review', id='review', required maxlength='500')
            button(type='submit') Create Review