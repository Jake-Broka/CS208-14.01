doctype html
html
  head
    title Downtown Donuts
    link(rel='stylesheet', href='/stylesheets/style.css')
    link(href='/images/logoLight.png' type='/image/png' rel='icon')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
  body
    div.top
      h1.italianno-regular
        img(src='/images/logoDark.png' alt='Downtown Donuts logo in gold' width='150px')
      a(href='/') Home 
      a(href='/menu') Menu 
      a(href='/about') About Us 
      a(href='/reviews') Leave a Review 
    hr.saffron

    block content

  br
  br

  footer
    hr.saffron
    div.bottom
      ul.schedule.no-bullet
        li.schedule-item
          span.date Monday:      
          span.time 8:00 A.M. - 8:00 P.M.
        li.schedule-item 
          span.date Tuesday:      
          span.time 8:00 A.M. - 8:00 P.M.
        li.schedule-item 
          span.date Wednesday:      
          span.time 8:00 A.M. - 8:00 P.M.
        li.schedule-item 
          span.date Thursday:      
          span.time 8:00 A.M. - 8:00 P.M.
        li.schedule-item 
          span.date Friday:      
          span.time 8:00 A.M. - 8:00 P.M.
        li.schedule-item 
          span.date Saturday:      
          span.time 8:00 A.M. - 8:00 P.M.
        li.schedule-item 
          span.date Sunday:      
          span.time 8:00 A.M. - 8:00 P.M.
      
      a(href='https://www.doordash.com/' target='_blank')
        img(src="/images/doordashLogo.png", alt="Doordash image link")
      a(href='https://www.ubereats.com/' target='_blank')
        img(src="/images/uberLogo.png", alt="Uber Eats image link")